# ── AI Provider API Keys（至少設定一個）──

# Google Gemini（推薦，有免費額度）
# 支援多組 key 輪替！用逗號分隔，或分開設定
# 方式一：逗號分隔
GEMINI_API_KEY=your-key-1,your-key-2,your-key-3
# 方式二：分開設定（兩種可混用）
# GEMINI_API_KEY=your-key-1
# GEMINI_API_KEY_2=your-key-2
# GEMINI_API_KEY_3=your-key-3

# OpenRouter（統一入口，200+ 模型，部分免費）
# 申請：https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key

# Anthropic（品質最好，但最貴）
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ── 每階段模型設定（可選，不設就用預設 fallback 順序）──
# 格式：provider:model（逗號分隔 = fallback 順序）
#
# AI_MODEL_OPENING=gemini:gemini-2.0-flash,openrouter:google/gemini-2.0-flash-exp:free
# AI_MODEL_DISCUSSION=gemini:gemini-2.0-flash,openrouter:google/gemini-2.5-flash
# AI_MODEL_SUMMARY=gemini:gemini-2.5-flash,anthropic:claude-sonnet-4-20250514
#
# 預設 fallback 順序：Gemini (免費) → OpenRouter → Anthropic

# ── API 用量監控（可選）──
# 每個 Gemini key 每天的免費額度上限
# GEMINI_DAILY_TOKEN_LIMIT=1000000
# GEMINI_DAILY_REQUEST_LIMIT=1500
