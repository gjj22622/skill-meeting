From 4412d82aacce28ead234c5b32f7f88dda70b3b1a Mon Sep 17 00:00:00 2001
From: Jacky <gjj22622@gmail.com>
Date: Sat, 28 Mar 2026 10:18:25 +0800
Subject: [PATCH] fix: clean Dockerfile/zeabur.json - remove PowerShell wrapper
 syntax

---
 .dockerignore | 2 --
 Dockerfile    | 2 --
 zeabur.json   | 4 +---
 3 files changed, 1 insertion(+), 7 deletions(-)

diff --git a/.dockerignore b/.dockerignore
index 7744d84..f3c1c62 100644
--- a/.dockerignore
+++ b/.dockerignore
@@ -1,8 +1,6 @@
-@"
 node_modules
 .next
 .git
 *.md
 .env*
 .DS_Store
-"@ | Set-Content -Path .dockerignore -Encoding UTF8
\ No newline at end of file
diff --git a/Dockerfile b/Dockerfile
index 0bbbda2..977e6f2 100644
--- a/Dockerfile
+++ b/Dockerfile
@@ -1,4 +1,3 @@
-@"
 FROM node:20-alpine AS builder
 WORKDIR /app
 COPY package.json package-lock.json ./
@@ -16,4 +15,3 @@ COPY --from=builder /app/.next/static ./.next/static
 COPY --from=builder /app/public ./public
 EXPOSE 3000
 CMD ["node", "server.js"]
-"@ | Set-Content -Path Dockerfile -Encoding UTF8
\ No newline at end of file
diff --git a/zeabur.json b/zeabur.json
index 2ab0ea8..b7b3562 100644
--- a/zeabur.json
+++ b/zeabur.json
@@ -1,6 +1,5 @@
-@"
 {
-  "`$schema": "https://schema.zeabur.app/template.json",
+  "$schema": "https://schema.zeabur.app/template.json",
   "build": {
     "type": "dockerfile"
   },
@@ -18,4 +17,3 @@
     }
   }
 }
-"@ | Set-Content -Path zeabur.json -Encoding UTF8
\ No newline at end of file
-- 
2.34.1

